{
  "name": "nisomnia",
  "type": "module",
  "version": "0.0.1",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "check": "bunx --bun astro check",
    "dev": "bunx --bun astro dev",
    "build": "bunx --bun astro build",
    "preview": "bunx --bun astro preview --host 0.0.0.0",
    "astro": "bunx --bun astro",
    "start": "bunx --bun run ./dist/server/entry.mjs --host 0.0.0.0",
    "db:check": "drizzle-kit check",
    "db:drop": "drizzle-kit drop",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit introspect",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:up": "drizzle-kit up",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,mts,js,jsx,mjs,json,md}\"",
    "format:write": "prettier --write \"**/*.{astro,ts,tsx,mts,js,jsx,mjs,json,md}\"",
    "lint": "eslint --ext .astro,.ts,.tsx,.js,.mjs ./src",
    "lint:fix": "eslint --ext .astro,.ts,.tsx,.js,.mjs ./src --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "0.9.5",
    "@astrojs/node": "9.5.0",
    "@astrojs/ts-plugin": "1.10.5",
    "@fontsource/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.1.16",
    "@trpc/client": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "@types/ioredis": "^5.0.0",
    "@yopem-ui/utils": "^0.0.2",
    "@yopem/try-catch": "^0.0.2",
    "astro": "5.15.2",
    "astro-embed": "^0.9.1",
    "astro-seo-meta": "^5.2.0",
    "astro-seo-schema": "^5.1.0",
    "dayjs": "^1.11.18",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "ioredis": "^5.8.2",
    "nanoid": "^5.1.6",
    "node-html-parser": "^7.0.1",
    "superjson": "^2.2.5",
    "tailwindcss": "^4.1.16",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.38.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/bun": "^1.3.1",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/parser": "^8.46.2",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "lefthook": "^2.0.2",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "packageManager": "bun@1.3.1"
}
