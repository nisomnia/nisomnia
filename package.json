{
  "name": "nisomnia",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "generate-routes": "tsr generate",
    "generate-api-types": "bun x openapi-typescript https://api.nisomnia.com/public/spec.json -o ./src/api/types.d.ts",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "prepare": "vp config",
    "predev": "bun run generate-api-types"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@unpic/react": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.6",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^1.21.0",
    "nitro": "npm:nitro-nightly@latest",
    "node-html-parser": "^8.0.2",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "4.1.9"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
