{
  "name": "nisomnia",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vp dev --port 3000",
    "generate-routes": "tsr generate",
    "generate-api-types": "bun x openapi-typescript https://api.nisomnia.com/public/spec.json -o ./src/api/types.d.ts",
    "build": "vp build",
    "preview": "vp preview",
    "start": "bun run .output/server/index.mjs",
    "test": "vp test run",
    "prepare": "vp config",
    "predev": "bun run generate-api-types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@unpic/placeholder": "^0.1.2",
    "@unpic/react": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "isomorphic-dompurify": "^3.18.0",
    "lucide-react": "^1.22.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260628-090458-3df69609",
    "node-html-parser": "^8.0.3",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/router-cli": "^1.167.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.2.1",
    "vite-plus": "^0.2.1",
    "vitest": "4.1.9"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
